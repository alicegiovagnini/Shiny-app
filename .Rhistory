# functions: factorial
fact = function(x) if(x<=0) 1 else x*fact(x-1)
# Plot of Fig. 3.1 in [T]: no coincident birthdays
x = 1:100
pb = function(n) prod(1- (1:(n-1))/365)
plot(x, sapply(x, pb), pch=16, cex=0.5, main="coincident birthdays")
# global variables
adda = function(x) {
x+a # global variable a
}
a=3; adda(8) # return 8+a
# local variables
add5 = function(x) {
a=5 # local variable, overrides global with same name
x+a
}
a=3; add5(8)
# pass by value
change = function(x) {
x[1] = 100
x
}
a=list(first=1, second=2); change(a)
# same for vectors - try in Python, what does it happen?
w=c(0,1,2); change(w)
w = change(w) # w is changed
w
install.packages("shiny")
library(shiny)
# --- UI ---
ui <- fluidPage(
# Titolo dell'app
titlePanel("La mia prima Shiny App"),
# Layout con una barra laterale e uno spazio principale
sidebarLayout(
# Barra laterale per gli INPUT
sidebarPanel(
sliderInput(inputId = "numero_colonne", # Nome in codice dell'input
label = "Scegli il numero di colonne:",
min = 1,
max = 50,
value = 30) # Valore di partenza
),
# Spazio principale per gli OUTPUT
mainPanel(
plotOutput(outputId = "mio_grafico") # Nome in codice del grafico
)
)
)
# --- SERVER ---
server <- function(input, output) {
# Creiamo il grafico e lo assegniamo all'output
output$mio_grafico <- renderPlot({
# Generiamo dei dati casuali
dati <- rnorm(100)
# Disegniamo l'istogramma usando l'input dell'utente
# input$numero_colonne corrisponde allo slider nella UI!
hist(dati, breaks = input$numero_colonne, col = "skyblue", border = "white")
})
}
# --- ESECUZIONE ---
shinyApp(ui = ui, server = server)
library(shiny)
# --- UI ---
ui <- fluidPage(
# Titolo dell'app
titlePanel("La mia prima Shiny App"),
# Layout con una barra laterale e uno spazio principale
sidebarLayout(
# Barra laterale per gli INPUT
sidebarPanel(
sliderInput(inputId = "numero_colonne", # Nome in codice dell'input
label = "Scegli il numero di colonne:",
min = 1,
max = 50,
value = 30) # Valore di partenza
),
# Spazio principale per gli OUTPUT
mainPanel(
plotOutput(outputId = "mio_grafico") # Nome in codice del grafico
)
)
)
# --- SERVER ---
server <- function(input, output) {
# Creiamo il grafico e lo assegniamo all'output
output$mio_grafico <- renderPlot({
# Generiamo dei dati casuali
dati <- rnorm(100)
# Disegniamo l'istogramma usando l'input dell'utente
# input$numero_colonne corrisponde allo slider nella UI!
hist(dati, breaks = input$numero_colonne, col = "skyblue", border = "white")
})
}
# --- ESECUZIONE ---
shinyApp(ui = ui, server = server)
